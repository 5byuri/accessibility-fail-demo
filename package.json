{
  "name": "pa11y-wcag-violation-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Intentionally inaccessible static demo pages for Pa11y/WCAG training.",
  "scripts": {
    "build": "node scripts/build-cloudflare-pages.mjs",
    "build:cloudflare-pages": "npm run build",
    "serve": "npx http-server . -p 8080 -c-1",
    "serve:python": "python3 -m http.server 8080",
    "test:all": "pa11y-ci --config .pa11yci",
    "test:one": "pa11y http://localhost:8080/pages/all-in-one.html --runner axe --runner htmlcs --standard WCAG2AAA --include-warnings --include-notices",
    "test:htmlcs": "pa11y http://localhost:8080/pages/all-in-one.html --runner htmlcs --standard WCAG2AAA --include-warnings --include-notices",
    "test:axe": "pa11y http://localhost:8080/pages/all-in-one.html --runner axe --standard WCAG2AAA --include-warnings --include-notices"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "pa11y": "^9.0.0",
    "pa11y-ci": "^4.0.0"
  }
}
